    {
      "name": "1. Registrasi & Login",
      "item": [
        {
          "name": "Submit Registration",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.success && jsonData.user) {",
                  "    pm.collectionVariables.set(\"userId\", jsonData.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Affiliate\",\n  \"lastName\": \"Test\",\n  \"email\": \"affiliate_{{$timestamp}}@comisio.com\",\n  \"password\": \"password123\",\n  \"role\": \"affiliate\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "signup"
              ]
            }
          }
        },
        {
          "name": "Login Akun (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@comisio.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "login"
              ]
            }
          }
        }
      ]
